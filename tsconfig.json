{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "module": "preserve",
    "lib": [
      "esnext",
      "dom"
    ],
    "jsx": "react-native",
    "esModuleInterop": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "App.tsx",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "supabase",
    "node_modules"
  ]
}